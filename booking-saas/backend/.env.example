# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/smartbook

# ========================================
# Server Configuration
# ========================================
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ========================================
# Authentication
# ========================================
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# ========================================
# Payment Processing (Stripe)
# ========================================
# Required for pricing tiers and subscription management
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ========================================
# Email Service (SendGrid)
# ========================================
# Required for booking confirmations, reminders, invoices
SENDGRID_API_KEY=SG.your_sendgrid_key
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_FROM_EMAIL=noreply@smartbook.com

# ========================================
# SMS Service (Twilio)
# ========================================
# Required for SMS notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# Google Calendar Integration
# ========================================
# Required for Google Calendar 2-way sync
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/google/callback

# ========================================
# Redis Cache
# ========================================
# Required for performance optimization (optional - will degrade gracefully)
REDIS_URL=redis://localhost:6379

# ========================================
# Feature Flags
# ========================================
ENABLE_2FA=true
ENABLE_PRICING_TIERS=true
ENABLE_GOOGLE_CALENDAR=true
ENABLE_ZAPIER_INTEGRATION=true
